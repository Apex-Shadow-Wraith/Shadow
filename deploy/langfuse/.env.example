# Langfuse v3 self-hosted secrets — TEMPLATE
# Copy to .env and replace CHANGE_ME values. Generate strong secrets via
# `openssl rand -hex 32` (NEXTAUTH_SECRET / SALT / ENCRYPTION_KEY) and
# `openssl rand -hex 24` (passwords).

# Langfuse application secrets
NEXTAUTH_SECRET=CHANGE_ME
SALT=CHANGE_ME
ENCRYPTION_KEY=CHANGE_ME
NEXTAUTH_URL=http://localhost:3000

# Service-internal credentials
LANGFUSE_POSTGRES_USER=langfuse
LANGFUSE_POSTGRES_PASSWORD=CHANGE_ME
LANGFUSE_POSTGRES_DB=langfuse

CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=CHANGE_ME

REDIS_PASSWORD=CHANGE_ME

MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=CHANGE_ME

# Telemetry off — self-hosted instance, no phone-home
TELEMETRY_ENABLED=false
LANGFUSE_ENABLE_EXPERIMENTAL_FEATURES=false

# API keys — populated after first-run admin setup
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000
